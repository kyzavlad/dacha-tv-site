# ─── Sanity CMS ────────────────────────────────────────────
# Create a project at https://sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Read token from Sanity project settings → API → Tokens
SANITY_API_TOKEN=your_read_token

# ─── Supabase ───────────────────────────────────────────────
# Create a project at https://supabase.com
# Run the SQL in lib/supabase/schema.sql to create the inquiries table
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Telegram Bot ───────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram
# 2. Start a conversation with your bot or add it to a group
# 3. Get the chat_id by messaging the bot and checking:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Optional per-topic routing. Each falls back to TELEGRAM_CHAT_ID if unset.
# Flower inquiries / lavender bookings:
TELEGRAM_CHAT_ID_FLOWERS=
# Water-house bookings:
TELEGRAM_CHAT_ID_DAD=
# Manual catalog leads — natural products / beekeeping thread:
TELEGRAM_CHAT_ID_NATURAL=
# Manual catalog leads — metal / profnastil / building materials thread:
TELEGRAM_CHAT_ID_METAL=
# Forum topic (thread) IDs — set only if the target chat is a forum/supergroup
# with topics. Sent as message_thread_id. Numeric, e.g. 12.
TELEGRAM_TOPIC_NATURAL=
TELEGRAM_TOPIC_METAL=

# ─── Email (Resend) ─────────────────────────────────────────
# Create an account at https://resend.com
# Add and verify your sending domain
RESEND_API_KEY=re_your_api_key
OWNER_EMAIL=your@email.com
FROM_EMAIL=notifications@dacha-tv.com

# ─── Admin dashboard ────────────────────────────────────────
# Single password for the /admin route
# Use a strong password in production
ADMIN_PASSWORD=choose_a_strong_password

# ─── Cron / admin endpoints ─────────────────────────────────
# Shared secret for protected admin endpoints (catalog repair, manual seed, …).
# Pass as "Authorization: Bearer <secret>" or "x-cron-secret: <secret>".
CRON_SECRET=choose_a_long_random_secret

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dacha-tv.com

# ─── Analytics / conversion tracking ────────────────────────
# All optional — if unset, gtag never loads and every track* helper is a safe
# no-op (so the store works with zero analytics config). GA4 fires ecommerce
# events (search, view_item, add_to_cart, begin_checkout, purchase, phone_click);
# Google Ads fires the purchase conversion after a successful order.
# From Google Analytics 4 → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# From Google Ads → the conversion tag id (AW-XXXXXXXXXX) and the purchase
# conversion action's label. Both are required to send the Ads conversion.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=xxxxxxxxxxxxxxxxxxx
# Set to 1 to force analytics console.debug logging in production (for verifying
# events); otherwise logging is on only outside production.
NEXT_PUBLIC_ANALYTICS_DEBUG=0
