# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the legacy-migration credential TEMPLATE is meant to be tracked.
# Real secrets (.env.legacy.local / .env.local) stay ignored by the rule above.
!.env.legacy.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# local data backups (never commit exported business data)
/backups/*
!/backups/README.md

# Local legacy migration reports
audit/legacy-catalog/
