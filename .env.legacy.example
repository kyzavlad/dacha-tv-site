# ============================================================================
# .env.legacy.example — TEMPLATE for the one-time legacy catalog audit/migration
# ============================================================================
# Copy the values into your local environment (e.g. `.env.legacy.local`, which is
# gitignored) and load them before running the scripts. NEVER commit real keys.
#
#   set -a; . ./.env.legacy.local; set +a
#   node scripts/audit-legacy-catalog.ts                      # read-only audit
#   node scripts/migrate-legacy-catalog.ts                    # dry-run plan
#   node scripts/migrate-legacy-catalog.ts --apply --confirm=I-UNDERSTAND-WRITE-TO-CURRENT
#
# Service-role keys are read at runtime only and are never printed or written to
# any report artifact.
# ============================================================================

# Current (authoritative) Supabase — reuses the app's existing variables.
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_current_service_role_key

# Legacy (source) Supabase — read-only source material.
LEGACY_SUPABASE_URL=https://REPLACE_ME.supabase.co
LEGACY_SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_legacy_service_role_key
